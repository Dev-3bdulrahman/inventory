{
  "name": "dev-3bdulrahman/inventory",
  "description": "An Inventory management module for Laravel ERP — warehouses, stock, transfers, adjustments & serial/batch tracking.",
  "type": "library",
  "version": "1.0.2",
  "license": "MIT",
  "authors": [
    {
      "name": "Abdulrahman",
      "homepage": "https://3bdulrahman.com",
      "role": "Developer"
    }
  ],
  "require": {
    "php": "^8.2|^8.3",
    "laravel/framework": "^11.0|^12.0"
  },
  "autoload": {
    "psr-4": {
      "Dev3bdulrahman\\Inventory\\": "src/"
    }
  },
  "extra": {
    "laravel": {
      "providers": [
        "Dev3bdulrahman\\Inventory\\InventoryServiceProvider"
      ]
    }
  },
  "minimum-stability": "stable",
  "prefer-stable": true
}
